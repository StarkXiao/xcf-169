#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 [1/3] 运行类型检查..."
npx tsc --noEmit
if [ $? -ne 0 ]; then
  echo "❌ 类型检查未通过，请修复后再提交"
  exit 1
fi

echo "📝 [2/3] 运行代码风格检查..."
npx lint-staged
if [ $? -ne 0 ]; then
  echo "❌ 代码风格检查未通过，请修复后再提交"
  exit 1
fi

echo "🏗️  [3/3] 运行构建校验..."
npm run build
if [ $? -ne 0 ]; then
  echo "❌ 构建校验未通过，请修复后再提交"
  exit 1
fi

echo "✅ 全部检查通过！提交继续..."

